{
  "name": "monmate",
  "private": true,
  "version": "0.1.0",
  "description": "MonMate activity check-in platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @monmate/web",
    "build": "npm run build -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present",
    "lint": "npm run lint -ws --if-present"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "next": {
      "postcss": "^8.5.10"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
